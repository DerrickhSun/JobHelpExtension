{
    "description": "A simple extension.",
    "version": "1.0",
    "manifest_version": 3,
    "name": "Simple Extension",
    "icons": {
        "256": "icons/border-256.png"
    },
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["https://*/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "simple-extension@example.com",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "action": {
        "default_popup": "popup.html"
    }
}